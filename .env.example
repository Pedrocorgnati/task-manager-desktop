# ============================================
# VARIAVEIS DE AMBIENTE - Task Manager Desktop
# ============================================
# Exemplo de arquivo .env para desenvolvimento
# Copie para .env e preencha conforme necessario
# ============================================

# Ambiente de execucao (development | staging | production)
APP_ENV=development

# Python environment
PYTHONENV=development

# Modo debug
DEBUG=true

# Nivel de logging
LOG_LEVEL=DEBUG

# Diretorio XDG para dados de usuario (opcional)
# Use para sobrescrever o diretorio padrao ~/.local/share
# XDG_DATA_HOME=~/.local/share

# Configuracoes opcionais para desenvolvimento
# PYTHONDONTWRITEBYTECODE=1
# PYTHONUNBUFFERED=1
